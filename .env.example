SHELLY_IP=192.168.x.x
SHELLY_NAME=your_device_name

# SHELLY_DEVICE_ID is almost always 0.
# Shelly plugs have a single relay (switch 0). Multi-channel devices like the Shelly 2PM
# have two relays (switch 0 and switch 1) — each gets its own ShellyPlug instance
# with a different DEVICE_ID pointing to the same IP.
# If you have multiple single-relay plugs, each has its own IP address — so you'd
# create multiple ShellyPlug instances with different IPs, not different DEVICE_IDs.
SHELLY_DEVICE_ID=0